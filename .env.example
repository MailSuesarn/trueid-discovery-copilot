# =============================================================================
# Copy this file to `.env` and fill in your real key. `.env` is gitignored.
#   cp .env.example .env
# In Google Colab you do NOT use this file — the notebook prompts for the key
# via getpass (see NOTEBOOK_GUIDE.md). Nothing is ever committed.
# =============================================================================

# Required for `provider` LLM mode + embeddings. If empty, the app still runs
# in deterministic `extractive` mode (see ARCHITECTURE.md §LLM Gateway).
OPENAI_API_KEY=

# Optional overrides (defaults live in configs/app.yaml — only set to override)
# LLM_MODE=provider          # provider | extractive | mock
# OPENAI_MODEL=gpt-5.5        # flagship reasoning model
# OPENAI_MODEL_CHEAP=gpt-5.4-mini
# OPENAI_EMBED_MODEL=text-embedding-3-large
# APP_CONFIG=configs/app.yaml
